<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://android.com"
    package="com.hinglish.cipherkeyboard">

    <application
        android:allowBackup="true"
        android:label="Hinglish Cipher Keyboard"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light">

        <!-- Settings Activity: required so system configuration screen doesn't crash -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Hinglish Cipher Keyboard Settings">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Input Method Service Declaration -->
        <service
            android:name=".HinglishCipherKeyboard"
            android:label="Hinglish Cipher Keyboard"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>
